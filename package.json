{
  "name": "@shirelshitrit/mantis-mcp",
  "version": "0.1.0",
  "description": "MCP (Model Context Protocol) server exposing the Mantis Bug Tracker REST API as tools for LLM clients (Claude Desktop, Claude Code, Cursor, etc.).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mantis-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mantis",
    "mantisbt",
    "mantishub",
    "bug-tracker",
    "issue-tracker",
    "claude",
    "claude-desktop",
    "anthropic",
    "llm",
    "ai-tools",
    "rest-api"
  ],
  "author": "Shirel Shitrit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirel11/mantis-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/shirel11/mantis-mcp/issues"
  },
  "homepage": "https://github.com/shirel11/mantis-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
