# Base URL of your Mantis instance (no trailing slash needed).
# Example: https://my-instance.mantishub.io  or  https://mantis.example.com
MANTIS_URL=https://your-instance.mantishub.io

# API token. Create one in Mantis: My Account -> API Tokens -> Create.
# Mantis expects the raw token in the Authorization header (no "Bearer " prefix).
MANTIS_TOKEN=replace-with-your-token

# Access mode.
#   read       -> only GET endpoints are exposed (safe default).
#   readwrite  -> create / update / delete / admin endpoints are also exposed.
MANTIS_MODE=read
